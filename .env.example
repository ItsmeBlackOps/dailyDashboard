# Backend
SUBDOMAIN=dailydb
PORT=3004
JWT_SECRET=replace-me-with-a-secure-secret
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/your-db
NEW_RELIC_LICENSE_KEY=your-new-relic-license
NEW_RELIC_BACKEND_APP_NAME=dailydb-backend
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_NO_CONFIG_FILE=true
LOGFLARE_SOURCE_ID=
LOGFLARE_API_KEY=
LOGFLARE_ENDPOINT=https://api.logflare.app/logs

# Frontend
API_URL=http://localhost:3004
FRONTEND_PORT=8180
NEW_RELIC_FRONTEND_APP_NAME=dailydb-frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_OPEN=false

# Scraper service (vendored — runs in dailydb-scraper container)
APIFY_TOKEN=
RESUME_SCRAPE_LOCATION=
RESUME_SCRAPE_REMOTE=

# AI provider — OpusMax (OpenAI-compatible Claude gateway).
# Powers the backend AI services (reports, interview debriefs, interviewer
# questions, candidate/resume profiles, thanks-mail). Set the key in the real
# .env / deploy secret — never commit it (this repo is public).
OPUSMAX_API_KEY=
OPENAI_BASE_URL=https://api.opusmax.pro/v1
OPENAI_REPORTING_MODEL=claude-opus-4-8
# Optional per-service model overrides (default to OPENAI_REPORTING_MODEL):
# CANDIDATE_PROFILE_MODEL=claude-opus-4-8
# RESUME_PROFILE_MODEL=claude-opus-4-8

# Forge-AI service (vendored — runs in dailydb-forge-ai container)
FORGE_MODEL=gpt-4o-mini
