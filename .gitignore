/node_modules
frontend/node_modules/
# ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ignore build output
*.tsbuildinfo
backend/node_modules/
frontend/dist/
.env

# One-time migration scripts (never commit)
backend/scripts/extract-all-candidate-profiles.js

# Vendored services
scraper/.env
scraper/__pycache__/
scraper/data/
scraper/logs/
scraper/.venv/
scraper/*.pyc
forge-ai/.env
forge-ai/node_modules/
forge-ai/output/
resume-templates/output/

# Cleanup additions
.claude/launch.json
.superpowers/
frontend/.env.development
backend/newrelic_agent.log
backend/newrelic_agent.log.*
**/__pycache__/
*.pyc
*.pyo

# Blue/green deploy active state — VM-local only. The cicd-deploy.sh
# script writes whichever color is currently serving traffic to these
# files; committing them caused 'git reset --hard' to wipe every flip,
# which made every deploy build the same color repeatedly.
nginx/conf.d/upstreams/frontend.active.conf
nginx/conf.d/upstreams/backend.active.conf

# Local diagnostic dumps from Apify API exploration
.apify_runs.json
.input*.json
.a*.json

# Local DB exports (PII — never commit)
/mongo-archive/

# Local scratch HTML reports
/po-dry-run.html
/user-mgmt-audit.html
