{
  "manifest_version": 3,
  "name": "Interview Meeting Detector",
  "version": "1.0.0",
  "description": "Reports to the Daily Dashboard when an expert actually joins a Teams interview (in-call, not lobby).",
  "permissions": ["storage"],
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Interview Meeting Detector"
  }
}
