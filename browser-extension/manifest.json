{
  "manifest_version": 3,
  "name": "1. Interview Meeting Detector",
  "version": "1.7.2",
  "description": "Marks interviews as started on the company dashboard the moment a signed-in expert joins the Teams call (in-call, never lobby).",
  "permissions": [
    "storage",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://dailydb.silverspace.tech/*",
    "https://dailydf.silverspace.tech/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://dailydf.silverspace.tech/*",
        "http://localhost/*"
      ],
      "js": [
        "dashboard-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "1. Interview Meeting Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
