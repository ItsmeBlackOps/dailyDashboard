{
  "manifest_version": 3,
  "name": "Interview Meeting Detector",
  "version": "1.5.0",
  "description": "Reports to the Daily Dashboard when an expert actually joins a Teams interview (in-call, not lobby), and confirms its presence to the dashboard.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://dailydb.silverspace.tech/*",
    "https://dailydf.silverspace.tech/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://dailydf.silverspace.tech/*", "http://localhost/*"],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Interview Meeting Detector"
  }
}
