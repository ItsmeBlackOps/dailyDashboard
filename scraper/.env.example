# ── Scraper environment variables ────────────────────────────────────────────
# Copy this file to .env and fill in the values for local development.

# Apify API token — required for Fantastic Jobs and LinkedIn actors
APIFY_API_TOKEN=

# OpenAI key — used by scrape_with_resume.py for resume parsing / title derivation
OPENAI_API_KEY=

# ── Remote / location filters (set by scraper/server.py) ─────────────────────
# Usually injected by the FastAPI wrapper; you can override for manual runs.
RESUME_SCRAPE_REMOTE=remote
RESUME_SCRAPE_LOCATION=

# ── Multi-title mode (set by scraper/server.py) ───────────────────────────────
# When "1", the script fans out across multiple derived job titles.
RESUME_SCRAPE_MULTI_TITLE=1

# ── Dashboard-driven profile overrides (set by resumeProfileService.js) ──────
# When the dailyDashboard backend has already derived a search profile from the
# candidate's resume via OpenAI (stored as candidateDetails.forgeProfile), it
# forwards these env vars to skip the scraper's internal LLM derivation step.
# They are injected by scraper/server.py; you can set them manually for testing.
#
# Comma-separated list of job titles to search:
RESUME_SCRAPE_OVERRIDE_TITLES=
#
# Comma-separated description keywords (1-3 words each):
RESUME_SCRAPE_OVERRIDE_KEYWORDS=

# ── Fantastic Jobs Apify actor knobs ─────────────────────────────────────────
FANTASTIC_JOBS_REMOVE_AGENCY=true
FANTASTIC_JOBS_INCLUDE_AI=true
FANTASTIC_JOBS_INCLUDE_LINKEDIN=false
FANTASTIC_JOBS_DESCRIPTION_TYPE=text
FANTASTIC_JOBS_AI_EMPLOYMENT_TYPES=FULL_TIME,CONTRACTOR
FANTASTIC_JOBS_AI_WORK_ARRANGEMENTS=On-site,Hybrid,Remote OK,Remote Solely
FANTASTIC_JOBS_COUNTRY=United States

# ── LinkedIn actor knobs ──────────────────────────────────────────────────────
LINKEDIN_NO_DIRECT_APPLY=true
